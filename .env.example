PORT=3000
HOST=0.0.0.0
# Leave DATABASE_URL empty to use local SQLite.
DATABASE_PATH=./data/restaurant-setup-pro.db
DATABASE_URL=
DATABASE_SSL=true
DATABASE_POOL_SIZE=5
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_INITIALIZATION_DELAY_MS=2000
DATABASE_RETRY_DELAY_MS=30000
RUN_MIGRATIONS=true
SESSION_HOURS=12
SEED_PASSWORD=replace-with-a-strong-initial-password
# Production-safe defaults. Enable only in isolated automated-test/demo databases.
SEED_ADMIN_EMAIL=admin@rspro.ai
DEMO_MODE=false
ENABLE_DEMO_SEED=false
RULES_MOCK_CONNECTOR_ENABLED=false
AI_IMAGE_PROVIDER=mock
OPENAI_API_KEY=
AI_IMAGE_MODEL=gpt-image-1
AI_IMAGE_SIZE=1024x1024
AI_IMAGE_MAX_PER_RUN=3
# Module 06A uses the deterministic rules provider in v1. Future adapters may select openai, gemini, claude, or qwen.
OPPORTUNITY_AI_PROVIDER=rules

# Google Places API (New) server-side Connector. Keep the API key in local/Render secrets only.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_CONNECTOR_ENABLED=false
GOOGLE_PLACES_API_BASE_URL=https://places.googleapis.com
GOOGLE_PLACES_TEXT_SEARCH_FIELD_MASK=places.id,places.displayName,places.formattedAddress,places.addressComponents,places.primaryType,places.types,places.googleMapsUri,places.websiteUri,places.nationalPhoneNumber,places.businessStatus,nextPageToken
GOOGLE_PLACES_REQUEST_TIMEOUT_MS=30000
# Configurable budget estimate only; not Google's final billed amount.
GOOGLE_PLACES_ESTIMATED_PRICE_PER_REQUEST_USD=0.035

# Geoapify Places server-side Connector (free-plan acceptance path).
GEOAPIFY_API_KEY=
GEOAPIFY_LOCATION_PROVIDER_ENABLED=true
GEOAPIFY_CONNECTOR_ENABLED=true
GEOAPIFY_API_BASE_URL=https://api.geoapify.com
GEOAPIFY_REQUEST_TIMEOUT_MS=30000
# Set to 0 for free-plan acceptance; credits remain tracked separately.
GEOAPIFY_CREDIT_VALUE_USD=0

# Connector-independent Website & Evidence Enrichment.
# Provider websites are always checked first. DuckDuckGo HTML discovery is used only when a Lead has no website candidate.
WEBSITE_ENRICHMENT_DISCOVERY_PROVIDER=duckduckgo-html
WEBSITE_ENRICHMENT_REQUEST_TIMEOUT_MS=8000
WEBSITE_ENRICHMENT_MAX_RESPONSE_BYTES=1500000
WEBSITE_ENRICHMENT_MAX_ATTEMPTS=3
