PORT=3000
HOST=0.0.0.0
# Leave DATABASE_URL empty to use local SQLite.
DATABASE_PATH=./data/restaurant-setup-pro.db
DATABASE_URL=
DATABASE_SSL=true
DATABASE_POOL_SIZE=5
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_INITIALIZATION_DELAY_MS=2000
DATABASE_RETRY_DELAY_MS=30000
RUN_MIGRATIONS=true
SESSION_HOURS=12
SEED_PASSWORD=replace-with-a-strong-initial-password
AI_IMAGE_PROVIDER=mock
OPENAI_API_KEY=
AI_IMAGE_MODEL=gpt-image-1
AI_IMAGE_SIZE=1024x1024
AI_IMAGE_MAX_PER_RUN=3
